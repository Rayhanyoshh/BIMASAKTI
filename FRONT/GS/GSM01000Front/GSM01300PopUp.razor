@inherits R_Page
<R_StackLayout Row>
    <R_Grid @ref="@_gridCoAListToAssignRef"
            DataSource="_GSM1310ViewModel.CoAToAssignList"
            R_ServiceGetListRecord="R_ServiceGetListRecordAsync"
            Pageable
            PageSize="10">
        <R_GridColumns>
            <R_GridTextColumn FieldName="CGLACCOUNT_NO" HeaderText="Account Code"></R_GridTextColumn>
            <R_GridTextColumn FieldName="CGLACCOUNT_NAME" HeaderText="Account Name"></R_GridTextColumn>
        </R_GridColumns>
    </R_Grid>
</R_StackLayout>

<R_StackLayout Row Class="justify-content-start">
    <R_ItemLayout xs="2">
        <R_Button OnClick="Button_OnClickOkAsync">
            Process
        </R_Button>
    </R_ItemLayout>
    <R_ItemLayout xs="2">
        <R_Button OnClick="Button_OnClickCloseAsync">
            Cancel
        </R_Button>
    </R_ItemLayout>
</R_StackLayout>